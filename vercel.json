{
  "version": 2,
  "functions": {
    "backend/src/index.js": {
      "runtime": "vercel-node@latest"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/src/index.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/frontend/dist/$1",
      "continue": true
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/frontend/dist/index.html"
    }
  ]
}