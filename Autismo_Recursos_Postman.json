{
  "info": {
    "name": "Autismo Recursos API",
    "description": "Colección de endpoints para el proyecto integrador Autismo Recursos.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Autenticación",
      "item": [
        {
          "name": "Registro",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@test.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [ "{{base_url}}" ],
              "path": [ "auth", "register" ]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@test.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [ "{{base_url}}" ],
              "path": [ "auth", "login" ]
            }
          }
        }
      ]
    },
    {
      "name": "Workspaces",
      "item": [
        {
          "name": "Obtener Públicos",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/workspaces/public",
              "host": [ "{{base_url}}" ],
              "path": [ "workspaces", "public" ]
            }
          }
        },
        {
          "name": "Obtener Mis Espacios",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/workspaces/my",
              "host": [ "{{base_url}}" ],
              "path": [ "workspaces", "my" ]
            }
          }
        },
        {
          "name": "Crear Workspace",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nuevo Espacio\",\n  \"description\": \"Descripción de prueba\",\n  \"visibility\": \"público\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/workspaces",
              "host": [ "{{base_url}}" ],
              "path": [ "workspaces" ]
            }
          }
        },
        {
          "name": "Eliminar Workspace",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/workspaces/AQUI_ID_DEL_WORKSPACE",
              "host": [ "{{base_url}}" ],
              "path": [ "workspaces", "AQUI_ID_DEL_WORKSPACE" ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000/api"
    },
    {
      "key": "token",
      "value": "pega_aqui_tu_token_jwt"
    }
  ]
}
